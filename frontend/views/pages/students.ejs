<!-- View All Students Page -->
<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold">All Students</h2>
        <p class="text-muted">View and manage all student records</p>
    </div>
</div>

<!-- Search Section -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label for="searchInput" class="form-label fw-bold">Search Students</label>
                        <input 
                            type="text" 
                            class="form-control" 
                            id="searchInput" 
                            placeholder="Search by name or roll number..."
                        >
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" id="searchBtn">Search</button>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-secondary w-100" id="clearSearchBtn">Clear</button>
                    </div>
                    <div class="col-md-2 text-end">
                        <a href="/students/add" class="btn btn-success w-100">+ Add New</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Students Table -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="studentsTable">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Roll Number</th>
                                <th>Name</th>
                                <th>Age</th>
                                <th>Gender</th>
                                <th>Course</th>
                                <th>Email</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="studentsTableBody">
                            <% if (students && students.length > 0) { %>
                                <% students.forEach(student => { %>
                                    <tr id="student-row-<%= student.id %>">
                                        <td><%= student.id %></td>
                                        <td><span class="badge bg-secondary"><%= student.roll_number %></span></td>
                                        <td class="fw-bold"><%= student.name %></td>
                                        <td><%= student.age %></td>
                                        <td><%= student.gender %></td>
                                        <td><%= student.course %></td>
                                        <td><%= student.email %></td>
                                        <td class="text-center">
                                            <a href="/students/edit/<%= student.id %>" class="btn btn-sm btn-warning me-1" title="Edit">Edit</a>
                                            <button class="btn btn-sm btn-danger delete-btn" data-id="<%= student.id %>" data-name="<%= student.name %>" title="Delete">Delete</button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">
                                        <p class="mt-2 mb-0">No students found.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white">
                <small class="text-muted" id="studentCount">
                    Total: <%= students ? students.length : 0 %> student(s)
                </small>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteStudentName"></strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>
