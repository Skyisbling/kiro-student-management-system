<div class="row">
    <!-- Project Overview Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-mortarboard-fill me-2"></i>Project Overview</h5>
            </div>
            <div class="card-body">
                <h6 class="fw-bold">Student Database Management System</h6>
                <p>
                    A web-based application designed to manage student records efficiently
                    using CRUD operations on a SQLite database.
                </p>
                <h6 class="fw-bold mt-3">Key Features:</h6>
                <ul class="mb-0">
                    <li>Student record management (add, view, edit, delete)</li>
                    <li>Search by name or roll number</li>
                    <li>Responsive interface with Bootstrap 5</li>
                    <li>SQLite database with auto-seeding</li>
                    <li>MVC architecture for clean code structure</li>
                    <li>Asynchronous operations using Fetch API</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Technologies Card -->
