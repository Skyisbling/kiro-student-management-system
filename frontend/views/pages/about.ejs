<div class="row">
    <!-- CRUD Operations Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i>CRUD Operations</h5>
            </div>
            <div class="card-body">
                <p>CRUD stands for the four basic database operations:</p>
                <table class="table table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Operation</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-success">Create</span></td>
                            <td>Add new students to the database</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-primary">Read</span></td>
                            <td>View and search student records</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-warning text-dark">Update</span></td>
                            <td>Modify existing student information</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-danger">Delete</span></td>
                            <td>Remove student records permanently</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Benefits Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-star-fill me-2"></i>Benefits of DBMS</h5>
            </div>
            <div class="card-body">
                <p>A Database Management System provides several advantages:</p>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Data Organization</strong> - Structured storage of information
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Easy Retrieval</strong> - Quick search and filter capabilities
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Data Integrity</strong> - Constraints ensure valid data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Reduced Redundancy</strong> - Eliminates duplicate data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Concurrent Access</strong> - Multiple users can access data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-caret-right-fill text-success me-2"></i>
                        <strong>Data Security</strong> - Control over who accesses data
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

