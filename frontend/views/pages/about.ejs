<div class="row">
    <!-- Project Overview Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-mortarboard me-2"></i>Project Overview</h5>
            </div>
            <div class="card-body">
                <h6 class="fw-bold">Student Database Management System</h6>
                <p>
                    This is a web-based application designed to manage student records efficiently.
                    It allows administrators to perform CRUD operations (Create, Read, Update, Delete)
                    on student data stored in a SQLite database.
                </p>
                <p>
                    The project demonstrates fundamental web development concepts including
                    server-side rendering, database management, RESTful routing, and
                    responsive design.
                </p>
            </div>
        </div>
    </div>

    <!-- Technologies Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Technologies Used</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-server me-3 text-success fs-4"></i>
                        <div>
                            <strong>Node.js</strong>
                            <br><small class="text-muted">JavaScript runtime for server-side programming</small>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-hdd-network me-3 text-primary fs-4"></i>
                        <div>
                            <strong>Express.js</strong>
                            <br><small class="text-muted">Web application framework for routing and middleware</small>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-database me-3 text-info fs-4"></i>
                        <div>
                            <strong>SQLite</strong>
                            <br><small class="text-muted">Lightweight relational database</small>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-file-earmark-code me-3 text-warning fs-4"></i>
                        <div>
                            <strong>EJS</strong>
                            <br><small class="text-muted">Embedded JavaScript templating engine</small>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-bootstrap me-3 text-purple fs-4"></i>
                        <div>
                            <strong>Bootstrap 5</strong>
                            <br><small class="text-muted">CSS framework for responsive design</small>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- CRUD Operations Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-arrow-repeat me-2"></i>CRUD Operations</h5>
            </div>
            <div class="card-body">
                <p>CRUD stands for the four basic database operations:</p>
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Operation</th>
                            <th>Action</th>
                            <th>HTTP Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>C</strong>reate</td>
                            <td>Add new student records</td>
                            <td><span class="badge bg-success">POST</span></td>
                        </tr>
                        <tr>
                            <td><strong>R</strong>ead</td>
                            <td>View student records</td>
                            <td><span class="badge bg-primary">GET</span></td>
                        </tr>
                        <tr>
                            <td><strong>U</strong>pdate</td>
                            <td>Edit student records</td>
                            <td><span class="badge bg-warning text-dark">POST</span></td>
                        </tr>
                        <tr>
                            <td><strong>D</strong>elete</td>
                            <td>Remove student records</td>
                            <td><span class="badge bg-danger">DELETE</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Benefits Card -->
    <div class="col-md-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-check-circle me-2"></i>Benefits of DBMS</h5>
            </div>
            <div class="card-body">
                <p>A Database Management System provides several advantages:</p>
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Data Organization</strong> – Structured storage of information
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Easy Retrieval</strong> – Quick search and filter capabilities
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Data Integrity</strong> – Constraints ensure valid data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Reduced Redundancy</strong> – Eliminates duplicate data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Concurrent Access</strong> – Multiple users can access data
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                        <strong>Data Security</strong> – Control over who accesses data
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

